{
  "name": "@malikasadjaved/git-ai",
  "version": "1.1.2",
  "description": "AI that lives inside your Git workflow — commits, PRs, changelogs, code review",
  "keywords": [
    "git",
    "ai",
    "commit",
    "changelog",
    "pull-request",
    "claude",
    "openai",
    "ollama",
    "developer-tools"
  ],
  "homepage": "https://github.com/Malikasadjaved/git-ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Malikasadjaved/git-ai.git"
  },
  "license": "MIT",
  "type": "module",
  "bin": {
    "git-ai": "dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "hooks"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "ts-node --esm src/index.ts",
    "test": "vitest run",
    "lint": "eslint src --ext .ts",
    "release": "npm run build && npm publish",
    "prepublishOnly": "npm run build && npm run lint && npm test",
    "prepare": "npm run build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.28.0",
    "@google/generative-ai": "^0.19.0",
    "@inquirer/prompts": "^6.0.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "conf": "^13.0.0",
    "diff": "^7.0.0",
    "figures": "^6.1.0",
    "openai": "^4.57.0",
    "ora": "^8.1.0",
    "simple-git": "^3.27.0",
    "tiktoken": "^1.0.17",
    "update-notifier": "^7.0.0"
  },
  "devDependencies": {
    "@types/diff": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/update-notifier": "^6.0.8",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
